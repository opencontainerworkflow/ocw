# Example .env file for the env-secrets tutorial
# Values here are available as BOTH {{ env.VARNAME }} and {{ secrets.VARNAME }}

# Application configuration (typically non-sensitive)
APP_NAME=my-cool-app
APP_VERSION=1.0.0
LOG_LEVEL=debug

# API credentials (typically sensitive - referenced as secrets)
API_KEY=sk-test-12345-abcde
API_SECRET=super-secret-api-key-67890

# Database credentials (referenced as secrets)
DB_PASSWORD=mydbpassword123
