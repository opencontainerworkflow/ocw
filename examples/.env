# Example .env file for OCW workflows
# These values are available as {{ env.X }} and {{ secrets.X }}

# Application config
APP_VERSION=2.0.0
APP_NAME=my-awesome-app
DEPLOY_ENV=staging

# Database config (can be referenced as secrets)
DB_HOST=localhost
DB_PORT=5432
DB_USER=appuser
DB_PASSWORD=supersecret123

# API Keys (typically secrets)
API_KEY=sk-test-abc123xyz
WEBHOOK_SECRET=whsec_test_secret
